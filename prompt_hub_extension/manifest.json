{
    "manifest_version": 3,
    "name": "Motiverse Prompt Hub",
    "version": "1.0.0",
    "description": "사내 직원용 AI 프롬프트 및 결과물 캡처, 중앙 DB 관리",
    "action": {
        "default_popup": "popup/popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "background": {
        "service_worker": "background/background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "https://chatgpt.com/*",
                "https://api.openai.com/*",
                "https://gemini.google.com/*",
                "https://claude.ai/*",
                "https://midjourney.com/*"
            ],
            "js": [
                "content/content.js"
            ],
            "css": [
                "content/content.css"
            ]
        }
    ],
    "permissions": [
        "storage",
        "activeTab",
        "scripting",
        "tabs",
        "downloads"
    ],
    "host_permissions": [
        "https://*.supabase.co/*"
    ]
}